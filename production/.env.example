# Environment Configuration Template
# Copy this file to .env and fill in your values

# ============================================
# API Keys
# ============================================
SENDGRID_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=+14155238886

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ============================================
# Database
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/technova_support
REDIS_URL=redis://localhost:6379/0

# ============================================
# Vector Database (Knowledge Base)
# ============================================
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-west1-gcp
PINECONE_INDEX=technova-kb

# ============================================
# LLM Configuration
# ============================================
LLM_PROVIDER=openai
LLM_MODEL=gpt-4-turbo-preview
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=500

# ============================================
# Feature Flags
# ============================================
ENABLE_AUTO_ESCALATION=true
ENABLE_SENTIMENT_ANALYSIS=true
ENABLE_KNOWLEDGE_RETRIEVAL=true
HUMAN_REVIEW_MODE=sampling

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=20

# ============================================
# Monitoring
# ============================================
DATADOG_API_KEY=
LOG_LEVEL=INFO
ENABLE_METRICS=true

# ============================================
# SLA Configuration (in minutes)
# ============================================
SLA_P0_MINUTES=15
SLA_P1_MINUTES=60
SLA_P2_MINUTES=240
SLA_P3_MINUTES=1440

# ============================================
# Security
# ============================================
ENCRYPTION_KEY=
PII_REDACTION_ENABLED=true
GDPR_COMPLIANCE_MODE=true

# ============================================
# Deployment
# ============================================
ENVIRONMENT=development
CANARY_WEIGHT=0
DEBUG=false
